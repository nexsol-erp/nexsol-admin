{
  "name": "tradelink247-pos-launcher",
  "version": "1.0.0",
  "description": "Lightweight launcher for TradeLink247 POS — checks for updates and launches the correct version",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.nexsol.tradelink247.launcher",
    "productName": "TradeLink247 POS Launcher",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**",
      "ui/**"
    ],
    "extraFiles": [
      {
        "from": "launcher-config.json",
        "to": "launcher-config.json"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "artifactName": "TradeLink247-POS-Launcher-Setup.${ext}"
    },
    "portable": {
      "artifactName": "TradeLink247-POS-Launcher.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TradeLink247 POS",
      "installerIcon": null,
      "uninstallerIcon": null
    }
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^26.0.12"
  },
  "overrides": {
    "@noble/hashes": "1.6.1"
  }
}
